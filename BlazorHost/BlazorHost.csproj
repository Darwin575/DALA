<Project Sdk="Microsoft.NET.Sdk.BlazorWebAssembly">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <OverrideHtmlAssetPlaceholders>true</OverrideHtmlAssetPlaceholders>
    <BlazorCacheBootResources>false</BlazorCacheBootResources>
    <BlazorWebAssemblyLoadAllAssembliesAsStream>true</BlazorWebAssemblyLoadAllAssembliesAsStream>
    <BlazorFingerprintBlazorJs>false</BlazorFingerprintBlazorJs>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.AspNetCore.Components.WebAssembly" Version="10.0.7" />
    <PackageReference Include="Microsoft.AspNetCore.Components.WebAssembly.DevServer" Version="10.0.7" PrivateAssets="all" />
    <PackageReference Include="MudBlazor" Version="9.4.0" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\DALA.Core\DALA.Core.csproj" />
  </ItemGroup>

</Project>