@page "/diagnostic"
@using BlazorHost.Services
@using System.Text.Json.Serialization
@inject RustInterop RustEngine
@inject DuckDBInterop DuckDB
@inject IJSRuntime JSRuntime

<PageTitle>DALA - Diagnostics</PageTitle>

<div class="container mt-5">
    <div class="d-flex align-items-center mb-4">
        <div class="bg-primary text-white rounded-circle d-flex align-items-center justify-content-center me-3" style="width: 50px; height: 50px;">
            <i class="bi bi-cpu-fill"></i>
        </div>
        <h1 class="mb-0">System Bridge Diagnostics</h1>
    </div>

    <div class="row g-4">
        <!-- Rust WASM Section -->
        <div class="col-md-6">
            <div class="card h-100 border-0 shadow-sm">
                <div class="card-header bg-dark text-white border-0 py-3">
                    <h5 class="card-title mb-0">1. Rust WASM Engine</h5>
                </div>
                <div class="card-body">
                    <p class="text-muted small">Testing the JSInterop bridge to the Rust-compiled WebAssembly module via Web Worker.</p>
                    
                    <div class="input-group mb-3">
                        <span class="input-group-text bg-light border-end-0">
                            <i class="bi bi-person"></i>
                        </span>
                        <input type="text" class="form-control bg-light border-start-0" @bind="userName" placeholder="Enter name..." />
                        <button class="btn btn-primary px-4" @onclick="TestRustHello" disabled="@isRustLoading">
                            @if (isRustLoading) {
                                <span class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></span>
                                <span>Wait...</span>
                            } else {
                                <span>Test Rust</span>
                            }
                        </button>
                    </div>

                    @if (!string.IsNullOrEmpty(rustMessage)) {
                        <div class="alert @(rustMessage.StartsWith("Error") ? "alert-danger" : "alert-success") border-0 shadow-sm animate-fade-in">
                            <div class="d-flex">
                                <i class="bi @(rustMessage.StartsWith("Error") ? "bi-exclamation-triangle-fill" : "bi-check-circle-fill") me-2"></i>
                                <div>@rustMessage</div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>

        <!-- LocalStorage Section -->
        <div class="col-md-6">
            <div class="card h-100 border-0 shadow-sm">
                <div class="card-header bg-dark text-white border-0 py-3">
                    <h5 class="card-title mb-0">2. Storage Persistence</h5>
                </div>
                <div class="card-body text-center">
                    <p class="text-muted small text-start">Verifying browser localStorage access for future DuckDB persistence layers.</p>
                    
                    <button class="btn btn-outline-secondary w-100 py-2 mb-3" @onclick="TestLocalStorage">
                        <i class="bi bi-hdd-network me-2"></i> Run Persistence Test
                    </button>
 
                    @if (storageSuccess.HasValue) {
                        <div class="alert @(storageSuccess.Value ? "alert-success" : "alert-danger") border-0 shadow-sm animate-fade-in text-start">
                            <div class="d-flex">
                                <i class="bi @(storageSuccess.Value ? "bi-database-check" : "bi-database-exclamation") me-2"></i>
                                <div>@storageStatus</div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>

        <!-- DuckDB Section -->
        <div class="col-md-12">
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-primary text-white border-0 py-3 d-flex justify-content-between align-items-center">
                    <h5 class="card-title mb-0">3. DuckDB-Wasm Engine</h5>
                    <div class="d-flex gap-2">
                        @if (isPersistent) {
                            <span class="badge bg-info text-dark"><i class="bi bi-shield-check me-1"></i>Persistent (OPFS)</span>
                        }
                        <span class="badge @(duckdbStatus == "Ready" ? "bg-success" : "bg-warning text-dark")">@duckdbStatus</span>
                    </div>
                </div>
                <div class="card-body">
                    <div class="row align-items-center">
                        <div class="col-lg-8">
                            <p class="text-muted small">Initializing a real DuckDB-Wasm instance with <strong>OPFS (Origin Private File System)</strong>. This allows the database to persist between refreshes. Data is stored in <code>dala_main.db</code>.</p>
                            
                            <div class="d-flex gap-2">
                                <button class="btn btn-primary" @onclick="TestDuckDB" disabled="@isDuckDBLoading">
                                    @if (isDuckDBLoading) {
                                        <span class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></span>
                                        <span>Initializing...</span>
                                    } else {
                                        <i class="bi bi-play-fill me-1"></i>
                                        <span>Run SQL Test</span>
                                    }
                                </button>
                                <button class="btn btn-outline-danger" @onclick="ClearStorage" disabled="@isDuckDBLoading">
                                    <i class="bi bi-trash3 me-1"></i> Clear Storage
                                </button>
                            </div>
                        </div>
                        <div class="col-lg-4">
                            @if (!string.IsNullOrEmpty(duckdbResult)) {
                                <div class="mt-3 mt-lg-0 alert @(duckdbResult.StartsWith("Error") ? "alert-danger" : "alert-info") border-0 shadow-sm animate-fade-in">
                                    <div class="d-flex align-items-center">
                                        <i class="bi @(duckdbResult.StartsWith("Error") ? "bi-exclamation-octagon" : "bi-database-fill-gear") me-3 fs-4"></i>
                                        <div>
                                            <div class="fw-bold small opacity-75 text-uppercase">Result</div>
                                            <div class="font-monospace">@duckdbResult</div>
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>
                    </div>

                    <div class="mt-4 pt-3 border-top">
                        <h6 class="mb-3"><i class="bi bi-file-earmark-arrow-up me-2"></i>Large File Ingestion (CSV -> Parquet)</h6>
                        <div class="row g-3 align-items-center">
                            <div class="col-auto">
                                <input type="file" id="csvFileInput" class="form-control form-control-sm" accept=".csv" />
                            </div>
                            <div class="col-auto">
                                <button class="btn btn-success btn-sm px-3" @onclick="StartIngestion" disabled="@isIngesting">
                                    @if (isIngesting) {
                                        <span class="spinner-border spinner-border-sm me-1" role="status" aria-hidden="true"></span>
                                        <span>Ingesting...</span>
                                    } else {
                                        <i class="bi bi-cloud-upload me-1"></i>
                                        <span>Start Ingest</span>
                                    }
                                </button>
                            </div>
                        </div>

                        @if (isIngesting || ingestProgress > 0) {
                            <div class="mt-3">
                                <div class="d-flex justify-content-between mb-1 small">
                                    <span class="text-muted">Compaction Progress</span>
                                    <span class="fw-bold">@ingestProgress%</span>
                                </div>
                                <div class="progress" style="height: 10px;">
                                    <div class="progress-bar progress-bar-striped progress-bar-animated bg-success" 
                                         role="progressbar" 
                                         style="width: @(ingestProgress)%;" 
                                         aria-valuenow="@ingestProgress" 
                                         aria-valuemin="0" 
                                         aria-valuemax="100">
                                    </div>
                                </div>
                                @if (ingestProgress == 100) {
                                    <div class="mt-2 text-success small">
                                        <i class="bi bi-check2-all me-1"></i> Ingestion complete! Data is now persisted in OPFS.
                                    </div>
                                }
                            </div>
                        }

                        @if (existingTables.Any()) {
                            <div class="mt-4">
                                <div class="small fw-bold text-muted mb-2 text-uppercase">Existing Tables (OPFS Inventory)</div>
                                <div class="list-group list-group-flush border rounded-3 overflow-hidden shadow-sm">
                                    @foreach (var table in existingTables) {
                                        <div class="list-group-item list-group-item-action d-flex justify-content-between align-items-center @(selectedTable == table ? "list-group-item-primary" : "")" 
                                             @onclick="() => SelectTable(table)" style="cursor: pointer;">
                                            <div>
                                                <i class="bi bi-table me-2"></i>
                                                <span class="font-monospace">@table</span>
                                            </div>
                                            @if (selectedTable == table) {
                                                <span class="badge bg-primary rounded-pill">Active</span>
                                            }
                                        </div>
                                    }
                                </div>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>

        <div class="col-12 mt-4 animate-fade-in" style="animation-delay: 0.4s;">
            <div class="card border-0 shadow-sm overflow-hidden">
                <div class="card-header bg-dark text-white border-0 py-3 d-flex justify-content-between align-items-center">
                    <h5 class="card-title mb-0"><i class="bi bi-bar-chart-steps me-2"></i>Dataset Insights (Profiler)</h5>
                    @if (activeProfile != null) {
                        <span class="badge bg-secondary">@activeProfile.RowCount Rows | @activeProfile.ColumnCount Columns</span>
                    }
                </div>
                <div class="card-body">
                    @if (activeProfile == null) {
                        <div class="text-center py-5 text-muted">
                            <i class="bi bi-clipboard2-data fs-1 opacity-25"></i>
                            <p class="mt-3">No active dataset selected. Load or ingest a file to see insights.</p>
                        </div>
                    } else {
                        <div class="table-responsive" style="max-height: 600px; overflow-y: auto; overflow-x: auto;">
                            <table class="table table-hover align-middle mb-0">
                                <thead class="table-light sticky-top">
                                    <tr>
                                        <th>Column Name</th>
                                        <th>Data Type</th>
                                        <th>Missing Values (Nulls)</th>
                                        <th>Quality</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var col in activeProfile.Columns) {
                                        var stat = activeProfile.Summary?.FirstOrDefault(s => s.ColumnName == col.Name);
                                        <tr>
                                                <td class="font-monospace fw-bold text-nowrap">@col.Name</td>
                                                <td><span class="badge bg-light text-dark border">@col.Type</span></td>
                                                <td>
                                                    @if (Convert.ToInt64(col.NullCount?.ToString() ?? "0") > 0) {
                                                        <span class="text-danger fw-bold"><i class="bi bi-exclamation-triangle-fill me-1"></i>@col.NullCount</span>
                                                    } else {
                                                        <span class="text-success"><i class="bi bi-check-circle-fill me-1"></i>0</span>
                                                    }
                                                </td>
                                            <td>
                                                <div class="d-flex flex-column gap-1 small">
                                                    @if (stat != null) {
                                                        <div class="d-flex justify-content-between border-bottom pb-1">
                                                            <span class="text-muted">Min/Max:</span>
                                                            <span class="font-monospace fw-semibold">@stat.Min / @stat.Max</span>
                                                        </div>
                                                        <div class="d-flex justify-content-between border-bottom pb-1">
                                                            <span class="text-muted">Unique:</span>
                                                            <span class="badge bg-secondary">~@stat.ApproxUnique</span>
                                                        </div>
                                                        <div class="d-flex justify-content-between">
                                                            <span class="text-muted">Avg:</span>
                                                            <span class="font-monospace">@stat.Avg</span>
                                                        </div>
                                                    }
                                                </div>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>

    <div class="mt-5 pt-4 border-top text-center text-muted">
        <small>DALA Bridge Verification Utility &bull; v1.0.0 &bull; 2026 Standard</small>
    </div>
</div>

<style>
    .animate-fade-in {
        animation: fadeIn 0.3s ease-in-out;
    }
    @@keyframes fadeIn {
        from { opacity: 0; transform: translateY(10px); }
        to { opacity: 1; transform: translateY(0); }
    }
</style>

@code {
    private string userName = "Developer";
    private string? rustMessage;
    private bool isRustLoading = false;
    
    private bool? storageSuccess;
    private string? storageStatus;
 
    private string duckdbStatus = "Standby";
    private string? duckdbResult;
    private bool isDuckDBLoading = false;
    private bool isPersistent = false;
    private List<string> existingTables = new();
    private string? selectedTable;
    private TableProfile? activeProfile;
    private bool showAdvancedStats = false;
    
    private bool isIngesting = false;
    private int ingestProgress = 0;

    public class TableProfile {
        public object RowCount { get; set; } = 0;
        public int ColumnCount { get; set; }
        public List<ColumnProfile> Columns { get; set; } = new();
        public List<ColumnSummary> Summary { get; set; } = new();
    }

    public class ColumnSummary {
        [JsonPropertyName("column_name")]
        public string ColumnName { get; set; } = "";
        [JsonPropertyName("column_type")]
        public string ColumnType { get; set; } = "";
        [JsonPropertyName("min")]
        public string Min { get; set; } = "";
        [JsonPropertyName("max")]
        public string Max { get; set; } = "";
        [JsonPropertyName("avg")]
        public string Avg { get; set; } = "";
        [JsonPropertyName("approx_unique")]
        public string ApproxUnique { get; set; } = "";
        [JsonPropertyName("null_count")]
        public object NullCount { get; set; } = 0;
    }

    public class ColumnProfile {
        public string Name { get; set; } = "";
        public string Type { get; set; } = "";
        public object NullCount { get; set; } = 0;
    }

    private async Task TestRustHello() {
        try {
            isRustLoading = true;
            rustMessage = null;
            // Add a tiny delay to show the spinner (simulating worker overhead)
            await Task.Delay(300);
            rustMessage = await RustEngine.SayHelloAsync(userName);
        } catch (Exception ex) {
            rustMessage = $"Error: {ex.Message}";
        } finally {
            isRustLoading = false;
        }
    }

    private async Task TestLocalStorage() {
        try {
            const string key = "dala_diagnostic_key";
            string value = $"verified_{DateTime.Now:yyyyMMdd_HHmmss}";
            
            await JSRuntime.InvokeVoidAsync("localStorage.setItem", key, value);
            var retrieved = await JSRuntime.InvokeAsync<string>("localStorage.getItem", key);
            
            if (retrieved == value) {
                storageSuccess = true;
                storageStatus = $"Persistence Verified: Wrote and retrieved unique timestamp '{retrieved}'.";
            } else {
                storageSuccess = false;
                storageStatus = $"Integrity Failure: Retrieved value '{retrieved}' did not match '{value}'.";
            }
        } catch (Exception ex) {
            storageSuccess = false;
            storageStatus = $"System Error: {ex.Message}";
        }
    }

    protected override async Task OnInitializedAsync() {
        try {
            // Wait for engine to be available (simple delay to avoid lock race)
            await Task.Delay(500);
            
            // Request inventory on boot
            using var objRef = DotNetObjectReference.Create(this);
            await DuckDB.GetInventoryAsync(objRef);
            
            // Restore session
            var storedTable = await JSRuntime.InvokeAsync<string?>("localStorage.getItem", "dala_active_table");
            
            // Sanitize: If the stored table name is the old dynamic format, purge it
            if (!string.IsNullOrEmpty(storedTable) && storedTable.StartsWith("dataset_") && storedTable != "dataset_main") {
                Console.WriteLine($"Purging obsolete dataset ID: {storedTable}");
                await JSRuntime.InvokeVoidAsync("localStorage.removeItem", "dala_active_table");
                storedTable = null;
            }

            selectedTable = storedTable;
            if (!string.IsNullOrEmpty(selectedTable)) {
                await ProfileTable(selectedTable);
            }
        } catch { }
    }

    private async Task ProfileTable(string tableName) {
        try {
            var json = await DuckDB.GetTableProfileAsync(tableName);
            
            // Check for pending import (e.g. after a version bump)
            using (var doc = System.Text.Json.JsonDocument.Parse(json)) {
                if (doc.RootElement.TryGetProperty("status", out var status) && status.GetString() == "pending_import") {
                    duckdbResult = "Database reset due to lock. Please re-ingest your dataset.";
                    activeProfile = null;
                    StateHasChanged();
                    return;
                }
            }

            activeProfile = System.Text.Json.JsonSerializer.Deserialize<TableProfile>(json, new System.Text.Json.JsonSerializerOptions {
                PropertyNameCaseInsensitive = true
            });
            StateHasChanged();
        } catch (Exception ex) {
            Console.WriteLine($"Profiling failed: {ex.Message}");
        }
    }

    [JSInvokable]
    public async Task OnInventoryUpdated(string[] tables) {
        existingTables = tables.ToList();
        await InvokeAsync(StateHasChanged);
    }

    private async Task TestDuckDB() {
        try {
            isDuckDBLoading = true;
            duckdbStatus = "Initializing...";
            duckdbResult = null;
            
            duckdbResult = await DuckDB.RunTestQueryAsync();
            duckdbStatus = "Ready";
            isPersistent = true; // Since we moved to OPFS in init
        } catch (Exception ex) {
            duckdbStatus = "Error";
            duckdbResult = $"Error: {ex.Message}";
        } finally {
            isDuckDBLoading = false;
        }
    }

    private async Task ClearStorage() {
        if (await JSRuntime.InvokeAsync<bool>("confirm", "Are you sure? This will delete the entire local database file (dala_main.db), clear session history, and reload the page.")) {
            await JSRuntime.InvokeVoidAsync("localStorage.removeItem", "dala_active_table");
            await DuckDB.ClearAllStorageAsync();
        }
    }

    private async Task SelectTable(string table) {
        selectedTable = table;
        await JSRuntime.InvokeVoidAsync("localStorage.setItem", "dala_active_table", table);
        await ProfileTable(table);
    }

    private void ResetDuckDB() {
        duckdbStatus = "Standby";
        duckdbResult = null;
        isPersistent = false;
    }

    [JSInvokable]
    public void OnIngestProgress(int progress) {
        ingestProgress = progress;
        StateHasChanged();
    }

    private async Task StartIngestion() {
        try {
            isIngesting = true;
            ingestProgress = 0;
            activeProfile = null;
            
            using var objRef = DotNetObjectReference.Create(this);
            // Fix ID mismatch: Use a stable table name for the primary dataset
            string tableName = "dataset_main"; 
            await DuckDB.IngestFromInputAsync("csvFileInput", tableName, objRef);
            
            // Save session
            selectedTable = tableName;
            await JSRuntime.InvokeVoidAsync("localStorage.setItem", "dala_active_table", tableName);
            
            // Profiling
            await ProfileTable(tableName);
            
            duckdbResult = $"Successfully ingested CSV into table '{tableName}'. Profiled {activeProfile?.RowCount} rows.";
        } catch (Exception ex) {
            duckdbResult = $"Ingestion Error: {ex.Message}";
        } finally {
            isIngesting = false;
        }
    }
}
