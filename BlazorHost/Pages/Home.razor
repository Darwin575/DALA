@page "/"
@using BlazorHost.Services
@inject RustInterop RustEngine
@inject DuckDBInterop DuckDB

<PageTitle>DALA - Home</PageTitle>

<h1>DALA: Data Analyst Local App</h1>

<div class="card mt-4">
    <div class="card-body">
        <h5 class="card-title">Rust Engine Outlier Detection</h5>
        <p class="card-text">Send a numeric array to Rust via Web Workers.</p>
        
        <div class="mb-3">
            <label class="form-label">Input Data (comma separated)</label>
            <input type="text" class="form-control" @bind="inputData" placeholder="1, 2, 3, 100, 4, 5" />
        </div>

        <button class="btn btn-primary" @onclick="AnalyzeData" disabled="@isProcessing">
            @if (isProcessing) {
                <span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span>
                <span> Processing...</span>
            } else {
                <span>Run IQR Analysis</span>
            }
        </button>

        @if (summary != null) {
            <div class="mt-4 alert alert-info">
                <h6>Results:</h6>
                <ul>
                    <li><strong>Outliers Found:</strong> @summary.Count</li>
                    <li><strong>Outlier Values:</strong> @string.Join(", ", summary.Outliers)</li>
                    <li><strong>Bounds:</strong> [@summary.LowerBound.ToString("F2"), @summary.UpperBound.ToString("F2")]</li>
                </ul>
            </div>
        }

        @if (!string.IsNullOrEmpty(error)) {
            <div class="mt-4 alert alert-danger">
                @error
            </div>
        }
    </div>
</div>

<div class="card mt-4">
    <div class="card-body">
        <h5 class="card-title">DuckDB Cleaning Hub</h5>
        <p class="card-text">Local SQL-based Mean/Median Imputation.</p>

        <div class="mb-3">
            <label class="form-label">Data with Missing Values (null for missing)</label>
            <input type="text" class="form-control" @bind="duckdbInput" placeholder="1, null, 3, null, 5" />
        </div>

        <div class="btn-group mb-3">
            <button class="btn btn-outline-secondary" @onclick='() => Impute("mean")' disabled="@isDuckDBProcessing">Mean Imputation</button>
            <button class="btn btn-outline-secondary" @onclick='() => Impute("median")' disabled="@isDuckDBProcessing">Median Imputation</button>
        </div>

        @if (!string.IsNullOrEmpty(duckdbResult)) {
            <div class="mt-4 alert alert-success">
                <h6>Cleaned Data:</h6>
                <pre>@duckdbResult</pre>
            </div>
        }
    </div>
</div>

@code {
    private string inputData = "1, 2, 3, 10, 4, 5, 6, 7, 8, 9, 100";
    private OutlierSummary? summary;
    private bool isProcessing = false;
    private string? error;

    // DuckDB State
    private string duckdbInput = "1, null, 3, null, 5, 10, 20";
    private string? duckdbResult;
    private bool isDuckDBProcessing = false;

    private async Task AnalyzeData() {
        try {
            isProcessing = true;
            error = null;
            summary = null;

            var data = inputData.Split(',')
                .Select(s => double.TryParse(s.Trim(), out var d) ? d : (double?)null)
                .Where(d => d.HasValue)
                .Select(d => d!.Value)
                .ToArray();

            if (data.Length == 0) {
                error = "Please enter valid numeric data.";
                return;
            }

            summary = await RustEngine.DetectOutliersAsync(data);
        } catch (Exception ex) {
            error = $"Error: {ex.Message}";
        } finally {
            isProcessing = false;
        }
    }

    private async Task Impute(string method) {
        try {
            isDuckDBProcessing = true;
            duckdbResult = null;

            var data = duckdbInput.Split(',')
                .Select(s => {
                    var trimmed = s.Trim().ToLower();
                    if (trimmed == "null" || string.IsNullOrEmpty(trimmed)) return (double?)null;
                    return double.TryParse(trimmed, out var d) ? d : (double?)null;
                })
                .ToArray();

            duckdbResult = await DuckDB.ImputeMissingValuesAsync(data, method);
        } catch (Exception ex) {
            duckdbResult = $"Error: {ex.Message}";
        } finally {
            isDuckDBProcessing = false;
        }
    }
}
